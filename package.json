{
  "name": "cgao",
  "version": "0.0.0",
  "private": true,
  "description": "Claude GitHub Automation Orchestrator — SDLC automation around Claude Code + GitHub.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "pnpm -r --filter=./apps/* --filter=./packages/* --filter=./tests/* run build",
    "dev": "pnpm -r --parallel --filter=./apps/* run dev",
    "test": "pnpm -r --filter=./apps/* --filter=./packages/* --filter=./tests/* run test",
    "test:security": "pnpm --filter @cgao/security-tests test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r --filter=./apps/* --filter=./packages/* --filter=./tests/* run typecheck",
    "db:generate": "pnpm --filter @cgao/db run generate",
    "db:migrate": "pnpm --filter @cgao/db run migrate",
    "dev:up": "docker compose -f infra/docker-compose.yml up -d",
    "dev:down": "docker compose -f infra/docker-compose.yml down",
    "commitlint": "commitlint --from=origin/main --to=HEAD"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/node": "^22.7.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
