# CGAO local development environment.
#
# Copy to `.env.local` (gitignored) and edit. Defaults align with
# infra/docker-compose.yml so `docker compose up` + `pnpm dev` just works.

DATABASE_URL=postgres://cgao:cgao_dev@localhost:5432/cgao
NATS_URL=nats://localhost:4222
REDIS_URL=redis://localhost:6379

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=cgao
S3_SECRET_KEY=cgao_dev_secret
S3_BUCKET=cgao-artifacts

# Webhook ingress ports
ORCHESTRATOR_PORT=9000
RUNNER_BROKER_PORT=9100

# GitHub App credentials — DO NOT COMMIT REAL VALUES.
# These are provisioned by the Trusted Control Runner (spec §6.4, §13.1).
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
CGAO_CONTROL_TOKEN=
