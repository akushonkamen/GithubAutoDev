# CGAO Orchestrator environment template.
#
# Copy to `.env` and fill in real values. `.env` is gitignored — never
# commit secrets. Memory-mode boots (default, `CGAO_RUNTIME=memory`)
# read none of these; real-mode boots require the variables marked
# `[required when CGAO_RUNTIME=real]`.

# ---- Runtime mode ----
# memory (default): in-memory bus/dedup/suppression — used by `pnpm dev`
#                   without docker and by the test suite.
# real:             Postgres-backed dedup/suppression/workflow-run repos;
#                   real Octokit GitHub adapter; bus stays in-memory until
#                   NATS lands in Phase 2.
CGAO_RUNTIME=memory

# ---- HTTP server ----
# Port the orchestrator listens on. Default 8787.
PORT=8787

# ---- GitHub webhook secret ----
# Shared secret used to HMAC-verify incoming webhooks. Generate with:
#   openssl rand -hex 32
# [required when CGAO_RUNTIME=real] — must match the value configured on
# the GitHub App settings page. Memory mode falls back to `dev-secret`.
GITHUB_WEBHOOK_SECRET=dev-secret

# ---- GitHub App credentials ----
# Capture these from https://github.com/settings/apps/<your-app> after
# creating the App (see docs/github-app-setup.md).
# [required when CGAO_RUNTIME=real]
GITHUB_APP_ID=
# App private key — full .pem contents, multi-line. Most shells accept a
# single quoted string with embedded newlines; alternatively write the
# key to disk and have your process manager export it.
GITHUB_APP_PRIVATE_KEY=
# Installation ID — appears on the App install URL after you install to
# a repo (or query via the App API).
GITHUB_INSTALLATION_ID=

# ---- Bot identity ----
# Login of the CGAO App's bot user (used for origin suppression). Format
# is `<slug>[bot]` where `<slug>` is the App's slugified name.
CGAO_BOT_LOGIN=cgao-bot[bot]
# User-Agent suffix sent on outbound GitHub API requests.
CGAO_APP_USER_AGENT=cgao-orchestrator

# ---- Postgres ----
# Connection URL. The default matches the docker-compose dev services
# brought up by `pnpm dev:up`.
# [required when CGAO_RUNTIME=real]
DATABASE_URL=postgresql://cgao:cgao_dev@localhost:5432/cgao

# ---- Object storage (Phase 2 — ArtifactStore) ----
# Optional today; runtime.ts leaves artifacts=null in both modes. When
# T-M2-004 wires the real ArtifactStore, set these to point at MinIO
# (dev) or S3 (prod).
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=cgao-artifacts
S3_ACCESS_KEY_ID=cgao
S3_SECRET_ACCESS_KEY=cgao_dev_secret
S3_REGION=us-east-1

# ---- Subprocess git adapter (T-B1-003) ----
# Absolute path to the repo root the orchestrator is allowed to operate
# on. Defaults to the cwd of the orchestrator process when unset.
CGAO_REPO_ROOT=

# ---- Tunnel (dev only) ----
# Optional: a stable trycloudflare domain to use with `scripts/dev-tunnel.sh`.
# When unset the script asks cloudflare for a random quick-tunnel URL.
TUNNEL_DOMAIN=
